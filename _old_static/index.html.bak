</main>

<!-- floating project preview -->
<div id="preview" aria-hidden="true"></div>

<script>
document.getElementById('yr').textContent = new Date().getFullYear();
const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

/* ---- hero letter stagger ---- */
document.querySelectorAll('[data-split]').forEach(el=>{
  const text = el.textContent;
  el.textContent = '';
  [...text].forEach((c,i)=>{
    const s=document.createElement('span');
    s.className='ch';
    s.textContent=c===' '?'\u00A0':c;
    el.appendChild(s);
  });
});
if(!reduced){
  const chs=document.querySelectorAll('.hero-name .ch');
  chs.forEach((s,i)=>{
    s.animate([{transform:'translateY(110%)'},{transform:'translateY(0)'}],
      {duration:900,delay:120+i*28,easing:'cubic-bezier(.2,.7,.2,1)',fill:'forwards'});
  });
}else{
  document.querySelectorAll('.hero-name .ch').forEach(s=>s.style.transform='none');
}

/* ---- reveals ---- */
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.1,rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

/* ---- floating preview ---- */
const pv=document.getElementById('preview');
const INK='#101620',ACC='#2438F0',TINT='#DDE2FE',PAPER='#EDF1F6';
function svgFor(type,abbr){
  if(type==='chart'){
    let bars='';for(let i=0;i<9;i++){const h=30+Math.random()*110;bars+=`<rect x="${34+i*30}" y="${190-h}" width="16" height="${h}" rx="3" fill="${i===5?ACC:'rgba(255,255,255,.16)'}"/>`;}
    return `<svg viewBox="0 0 340 255" xmlns="http://www.w3.org/2000/svg"><rect width="340" height="255" fill="${INK}"/>${bars}<line x1="24" y1="192" x2="316" y2="192" stroke="rgba(255,255,255,.25)"/><text x="26" y="40" font-family="monospace" font-size="13" fill="${TINT}">${abbr} / analytics</text><text x="26" y="234" font-family="monospace" font-size="11" fill="rgba(255,255,255,.4)">df.groupby(...).agg(...)</text></svg>`;
  }
  if(type==='skel'){
    const cx=170,cy=130,s=1.4;
    const P=[[0,-46],[0,-30],[-16,-24],[-22,-4],[16,-24],[22,-4],[0,-6],[-10,22],[-12,48],[10,22],[12,48]].map(([x,y])=>[cx+x*s,cy+y*s]);
    const B=[[0,1],[1,2],[2,3],[1,4],[4,5],[1,6],[6,7],[7,8],[6,9],[9,10]];
    let g='';B.forEach(([a,b])=>{g+=`<line x1="${P[a][0]}" y1="${P[a][1]}" x2="${P[b][0]}" y2="${P[b][1]}" stroke="${ACC}" stroke-width="2" opacity=".85"/>`});
    P.forEach((p,i)=>{g+=`<circle cx="${p[0]}" cy="${p[1]}" r="${i===0?6:3.6}" fill="${i===0?TINT:ACC}"/>`});
    return `<svg viewBox="0 0 340 255" xmlns="http://www.w3.org/2000/svg"><rect width="340" height="255" fill="${INK}"/>${g}<text x="26" y="40" font-family="monospace" font-size="13" fill="${TINT}">${abbr} / vision·ml</text><text x="26" y="234" font-family="monospace" font-size="11" fill="rgba(255,255,255,.4)">model.predict(frame)</text></svg>`;
  }
  // grid = fullstack admin
  let cells='';for(let r=0;r<3;r++)for(let c=0;c<4;c++){const on=Math.random()>.55;cells+=`<rect x="${30+c*72}" y="${64+r*46}" width="60" height="34" rx="6" fill="${on?'rgba(36,56,240,.85)':'rgba(255,255,255,.12)'}"/>`;}
  return `<svg viewBox="0 0 340 255" xmlns="http://www.w3.org/2000/svg"><rect width="340" height="255" fill="${INK}"/><rect x="30" y="26" width="120" height="14" rx="4" fill="${TINT}"/><rect x="238" y="26" width="72" height="14" rx="7" fill="${ACC}"/>${cells}<text x="30" y="234" font-family="monospace" font-size="11" fill="rgba(255,255,255,.4)">admin.controls(everything)</text></svg>`;
}
let mx=0,my=0,px=0,py=0,active=false,rafId=null;
function loop(){
  px+=(mx-px)*.12;py+=(my-py)*.12;
  pv.style.left=(px+24)+'px';pv.style.top=(py-90)+'px';
  rafId=requestAnimationFrame(loop);
}
document.querySelectorAll('.wrow').forEach(row=>{
  row.addEventListener('mouseenter',e=>{
    pv.innerHTML='<div class="pv show">'+svgFor(row.dataset.pv,row.dataset.abbr)+'</div>';
    pv.classList.add('on');active=true;
    if(!reduced&&rafId===null){px=e.clientX;py=e.clientY;loop();}
  });
  row.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;if(reduced){pv.style.left=(mx+24)+'px';pv.style.top=(my-90)+'px';}});
  row.addEventListener('mouseleave',()=>{pv.classList.remove('on');active=false;if(rafId!==null){cancelAnimationFrame(rafId);rafId=null;}});
});

/* ---- hero skeleton canvas (kept from theme) ---- */
(function(){
  const canvas=document.getElementById('skel');const ctx=canvas.getContext('2d');
  let W,H,dpr,figures=[];
  const BONES=[[0,1],[1,2],[2,3],[1,4],[4,5],[1,6],[6,7],[7,8],[6,9],[9,10]];
  const base=()=>[{x:0,y:-46},{x:0,y:-30},{x:-16,y:-24},{x:-22,y:-4},{x:16,y:-24},{x:22,y:-4},{x:0,y:-6},{x:-10,y:22},{x:-12,y:48},{x:10,y:22},{x:12,y:48}];
  function make(){figures=[];const n=W<700?2:3;
    for(let i=0;i<n;i++)figures.push({cx:W*(0.55+i*0.18)+(Math.random()*30-15),cy:H*(0.3+Math.random()*0.25),scale:1.3+Math.random()*0.5,phase:Math.random()*6.28,speed:.5+Math.random()*.5,base:base()});}
  function resize(){dpr=Math.min(devicePixelRatio||1,2);W=canvas.clientWidth;H=canvas.clientHeight;canvas.width=W*dpr;canvas.height=H*dpr;ctx.setTransform(dpr,0,0,dpr,0,0);make();}
  function draw(f,t){const sw=Math.sin(t*.0006*f.speed+f.phase),st=Math.sin(t*.0012*f.speed+f.phase);
    const pts=f.base.map((p,i)=>{let x=p.x,y=p.y;if(i===3)x+=5*sw;if(i===5)x-=5*sw;if(i===8)x+=6*st;if(i===10)x-=6*st;if(i===0)x+=1.5*sw;
      return{x:f.cx+x*f.scale+sw*4,y:f.cy+y*f.scale};});
    ctx.lineWidth=1.4;ctx.strokeStyle='rgba(36,56,240,0.14)';ctx.beginPath();
    BONES.forEach(([a,b])=>{ctx.moveTo(pts[a].x,pts[a].y);ctx.lineTo(pts[b].x,pts[b].y);});ctx.stroke();
    pts.forEach((p,i)=>{ctx.beginPath();ctx.arc(p.x,p.y,i===0?4:2.4,0,6.28);ctx.fillStyle='rgba(36,56,240,0.3)';ctx.fill();});}
  function frame(t){ctx.clearRect(0,0,W,H);figures.forEach(f=>draw(f,t));requestAnimationFrame(frame);}
  resize();addEventListener('resize',()=>{resize();if(reduced){ctx.clearRect(0,0,W,H);figures.forEach(f=>draw(f,0));}});
  if(reduced){figures.forEach(f=>draw(f,0));}else{requestAnimationFrame(frame);}
})();
</script>
</body>
</html>
